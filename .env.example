# Supabase (project region: eu-west-2, London)
# New-style API keys (sb_publishable_… / sb_secret_…), not the legacy anon/service_role JWTs.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Exposed to the Next.js client bundle
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Postgres connection string — password must be percent-encoded
DATABASE_URL=

# Microsoft Graph (mail + calendar) — used from Session 7 onwards
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# Workflow time multiplier. Timers are data (workflow_definitions rows) x TIME_SCALE.
# Production = 1. Dev = 1440 (1 day -> 1 minute). Never hardcode a duration.
TIME_SCALE=1440

# Shared secret for the workflow tick endpoint (/api/workflows/tick).
# Vercel Cron sends it as `Authorization: Bearer <value>`; the endpoint fails
# closed (503) when unset. Generate a long random value; never commit it.
CRON_SECRET=
