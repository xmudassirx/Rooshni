# Supabase (project region: eu-west-2, London)
# New-style API keys (sb_publishable_… / sb_secret_…), not the legacy anon/service_role JWTs.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# Exposed to the Next.js client bundle
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Postgres connection string — password must be percent-encoded
DATABASE_URL=

# Microsoft Graph (mail + calendar) — the firm's outbound email carrier
# (Session 10). App-only client credentials; GRAPH_SENDER_ADDRESS is the
# mailbox the firm sends as. Tenant comms only — platform mail rides Resend
# and the two pipes never mix (decision 87).
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=
GRAPH_SENDER_ADDRESS=

# Meta Lead Ads webhook (Session 10). The endpoint fails closed without the
# app secret (signature check) and verify token (subscription handshake);
# META_ACCESS_TOKEN needs leads_retrieval for the page (the webhook ping
# carries ids only — field data is fetched). Graph API v25.0+ only.
META_APP_SECRET=
META_VERIFY_TOKEN=
META_ACCESS_TOKEN=

# WhatsApp Business Cloud API (Session 10) — approved template messages
# through the same approved-communication pipeline; session-window law is
# enforced in the readiness pre-flight.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Workflow time multiplier. Timers are data (workflow_definitions rows) x TIME_SCALE.
# Production = 1. Dev = 1440 (1 day -> 1 minute). Never hardcode a duration.
TIME_SCALE=1440

# Shared secret for the workflow tick endpoint (/api/workflows/tick).
# Vercel Cron sends it as `Authorization: Bearer <value>`; the endpoint fails
# closed (503) when unset. Generate a long random value; never commit it.
CRON_SECRET=

# Stripe (Session 9 — signup + activation webhook). TEST-MODE keys until the
# GO-LIVE tick; the webhook fails closed (503) without its signing secret.
# STRIPE_PRICE_ID is the Pilot · Firm £149/mo recurring price.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Platform mail (Resend) — pre-active signup reminders. Platform mail and
# tenant comms are separate pipes permanently (founder ruling, 17 Jul 2026).
# Production sending domain barakahx.com is a GO-LIVE item.
RESEND_API_KEY=
PLATFORM_MAIL_FROM=
